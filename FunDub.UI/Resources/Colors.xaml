<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ BACKGROUND LAYERS (darkest → lightest) ═══ -->
    <Color x:Key="Bg0Color">#0D0F12</Color>
    <Color x:Key="Bg1Color">#141820</Color>
    <Color x:Key="Bg2Color">#1A1F2B</Color>
    <Color x:Key="Bg3Color">#222838</Color>
    <Color x:Key="Bg4Color">#2A3245</Color>

    <SolidColorBrush x:Key="BackgroundMain"    Color="{StaticResource Bg1Color}"/>
    <SolidColorBrush x:Key="BackgroundSidebar" Color="{StaticResource Bg0Color}"/>
    <SolidColorBrush x:Key="BackgroundControl"  Color="{StaticResource Bg2Color}"/>
    <SolidColorBrush x:Key="BackgroundElevated" Color="{StaticResource Bg3Color}"/>
    <SolidColorBrush x:Key="BackgroundSurface"  Color="{StaticResource Bg4Color}"/>

    <!-- ═══ ACCENT ═══ -->
    <Color x:Key="AccentColor">#22D3A7</Color>
    <Color x:Key="AccentDimColor">#1AAD8A</Color>
    <Color x:Key="AccentGlowColor">#2AEDC0</Color>
    <Color x:Key="AccentMutedColor">#1A6B55</Color>

    <SolidColorBrush x:Key="Accent"       Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDim"    Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="AccentGlow"   Color="{StaticResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="AccentMuted"  Color="{StaticResource AccentMutedColor}"/>
    <SolidColorBrush x:Key="AccentGreen"  Color="#22D3A7"/>

    <!-- ═══ BORDERS ═══ -->
    <SolidColorBrush x:Key="BorderSubtle"  Color="#FF293148"/>
    <SolidColorBrush x:Key="BorderDefault" Color="#2A3345"/>
    <SolidColorBrush x:Key="AccentBorder"  Color="#2A3345"/>
    <SolidColorBrush x:Key="BorderHover"   Color="#3A4A60"/>

    <!-- ═══ TEXT ═══ -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#EAF0F6"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#8B99AE"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#FF7484A0"/>
    <SolidColorBrush x:Key="TextAccent"    Color="{StaticResource AccentColor}"/>

    <!-- ═══ STATUS ═══ -->
    <SolidColorBrush x:Key="StatusError"   Color="#FF4D6A"/>
    <SolidColorBrush x:Key="StatusWarning" Color="#FFB84D"/>
    <SolidColorBrush x:Key="StatusSuccess" Color="#22D3A7"/>

    <!-- ═══ SHADOWS ═══ -->
    <DropShadowEffect x:Key="ShadowSm" BlurRadius="8"  ShadowDepth="2" Opacity="0.3" Color="#000"/>
    <DropShadowEffect x:Key="ShadowMd" BlurRadius="16" ShadowDepth="4" Opacity="0.35" Color="#000"/>
    <DropShadowEffect x:Key="ShadowLg" BlurRadius="28" ShadowDepth="6" Opacity="0.4" Color="#000"/>

</ResourceDictionary>
