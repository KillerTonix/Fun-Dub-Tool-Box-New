<UserControl x:Class="FunDub.UI.Views.Controls.StatBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunDub.UI.Views.Controls"
             Margin="6,4">
    <Border Background="#141820" CornerRadius="8" Padding="14,12" BorderBrush="#1C2233" BorderThickness="1">
        <StackPanel Orientation="Vertical">
            <TextBlock x:Name="LabelDisplay" 
                       Text="LABEL" 
                       FontSize="10" 
                       FontWeight="Bold" 
                       Foreground="#566378"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,5"/>
            <TextBlock x:Name="ValueDisplay" 
                       Text="0" 
                       FontSize="22" 
                       FontWeight="SemiBold"
                       Foreground="#EAF0F6" 
                       HorizontalAlignment="Left"/>
        </StackPanel>
    </Border>
</UserControl>
