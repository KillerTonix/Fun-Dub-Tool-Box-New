<Window x:Class="FunDub.UI.Views.QueueProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FunDub.UI.Views"
        xmlns:vm="clr-namespace:FunDub.UI.ViewModels"
        xmlns:controls="clr-namespace:FunDub.UI.Views.Controls"
        mc:Ignorable="d"
        Title="Queue — Fun Dub Tool Box" Height="620" Width="960"
        Background="{StaticResource BackgroundMain}" Foreground="{StaticResource TextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── Toolbar ────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundSidebar}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="18,14">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="EditeSelectedQueueButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Edit Item" Click="EditSelectedQueueButton_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="14"/>
                    </Button>
                    <Button x:Name="ClearQueueButton" Style="{StaticResource ClearButtonStyle}" Width="40" Height="34" Margin="6,0,0,0" ToolTip="Clear Queue" Click="ClearQueueButton_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <Button x:Name="StartProcessingButton" Style="{StaticResource StartButtonStyle}" 
                        Width="180" Height="42" HorizontalAlignment="Right" Click="StartProcessingButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEDB5;" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StartTextBlock" Text="Start" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ─── Queue List ─────────────────────────────────────────── -->
        <Border Grid.Row="1" Margin="16,12" CornerRadius="10" 
                Background="{StaticResource BackgroundControl}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
            <ListView x:Name="QueueListView" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" Margin="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Output File" Width="310" DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Header="Step" Width="190" DisplayMemberBinding="{Binding CurrentStep}"/>
                        <GridViewColumn Header="Status" Width="110" DisplayMemberBinding="{Binding Status}"/>
                        <GridViewColumn Header="Progress" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Background="#0D1117" Height="8" Width="100">
                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding Progress}" MaxWidth="100">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#22D3A7" Offset="0"/>
                                                    <GradientStop Color="#1AAD8A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ─── Engine / Options ───────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundSidebar}" Padding="16,12" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,1">
            <Grid>
                <CheckBox x:Name="AutomaticShutdownPC" Content="Shutdown PC when finished" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Engine:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" FontWeight="SemiBold"/>
                    <ComboBox x:Name="RenderingEngineComboBox" Width="260" Style="{StaticResource ModernComboBoxStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── Progress Panel ─────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource BackgroundMain}" Padding="20,16">
            <StackPanel>
                <!-- Current Task -->
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="CURRENT TASK" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="CurrentRenderingFileLabel" Text="Waiting..." 
                               Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,0"/>
                </Grid>

                <!-- Progress Bar -->
                <Border CornerRadius="5" Background="#0D1117" Height="12">
                    <Border x:Name="OverallProgressBarBorder" CornerRadius="5" HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#22D3A7" Offset="0"/>
                                <GradientStop Color="#2AEDC0" Offset="0.5"/>
                                <GradientStop Color="#22D3A7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>
                <!-- Hidden WPF progress bar for value binding (used in code-behind) -->
                <ProgressBar x:Name="OverallProgressBar" Height="0" Visibility="Collapsed"/>

                <!-- Time Labels -->
                <Grid Margin="0,8,0,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Elapsed " Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock x:Name="ElapsedTimeLabel" Text="00:00:00" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Remaining " Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock x:Name="RemainingTimeLabel" Text="00:00:00" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Performance Monitor -->
                <Expander Foreground="{StaticResource TextMuted}" Background="Transparent">
                    <Expander.Header>
                        <TextBlock Text="PERFORMANCE MONITOR" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" />
                    </Expander.Header>
                    <Border Background="{StaticResource BackgroundSidebar}" CornerRadius="10" Padding="16,12" Margin="0,10,0,0"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                        <UniformGrid Columns="3" Rows="2">
                            <controls:StatBlock x:Name="FPSLabel" Label="FPS" Value="0"/>
                            <controls:StatBlock x:Name="CurrentFrameLabel" Label="Frame" Value="0"/>
                            <controls:StatBlock x:Name="BitrateLabel" Label="Bitrate" Value="0 kbps"/>
                            <controls:StatBlock x:Name="CPUUsageLabel" Label="CPU" Value="0%"/>
                            <controls:StatBlock x:Name="GPUUsageLabel" Label="GPU" Value="0%"/>
                            <controls:StatBlock x:Name="RAMUsageLabel" Label="RAM" Value="0 MB"/>
                        </UniformGrid>
                    </Border>
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>
